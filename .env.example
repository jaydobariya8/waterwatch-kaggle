# WaterWatch configuration — copy to `.env` and fill in. NEVER commit your real .env.
# The system runs fully offline with NONE of these set; they unlock the live integrations.

# --- Gemini (enables multimodal report parsing + nicer drafting) -------------
# Get a key from Google AI Studio (https://aistudio.google.com/app/apikey).
GEMINI_API_KEY=
# GOOGLE_API_KEY=                      # alias accepted as a fallback
GEMINI_MODEL_PRO=gemini-2.5-pro
GEMINI_MODEL_FLASH=gemini-2.5-flash

# --- Live civic data (data.gov.in / CPCB) ------------------------------------
DATA_GOV_API_KEY=

# --- State / memory ----------------------------------------------------------
# local (default, zero-setup JSON file) | firestore (live GCP deployment)
STORE_BACKEND=local
# FIRESTORE_PROJECT=your-gcp-project
# WATERWATCH_STORE_PATH=.waterwatch_store.json

# --- Watchdog / civic policy -------------------------------------------------
ESCALATION_DAYS=14
CLUSTER_THRESHOLD=3

# --- Web ---------------------------------------------------------------------
CORS_ORIGINS=*
LOG_LEVEL=INFO
